# ==============================================================================
# ÆHub GLOBAL PROJECT ROOT .GITIGNORE
# ==============================================================================

# =========================
# OS & EDITOR (Global)
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# System & Package Manager Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# FRONTEND (Next.js / Node)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.pnp
frontend/.pnp.js
frontend/*.tsbuildinfo
frontend/.next-env.d.ts
frontend/coverage/
frontend/.vercel

# Frontend Environment Secrets
frontend/.env
frontend/.env.local
frontend/.env*.local

# =========================
# BACKEND (Python / FastAPI)
# =========================
# Python Cache & Tooling Architectures
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
backend/.pytest_cache/
.ruff_cache/
backend/.ruff_cache/

# Virtual Environments Binds
.venv/
venv/
backend/venv/
backend/env/
backend/.venv/

# Backend Environment Secrets & Database
backend/.env
backend/.env.*
backend/*.db
backend/*.sqlite3
# Ignore SQLite WAL mode temporary files
backend/*.db-wal
backend/*.db-shm

# ==============================================================================
# ÆHub MEDIA & AUDIO CACHE
# ==============================================================================
backend/downloads/
backend/temp_downloads/
backend/audio_cache/
backend/temp_input.webm

# ==============================================================================
# ÆHub GOOGLE AGENT SECRETS (CRITICAL)
# Prevents Google Cloud API credentials and persistent OAuth tokens from leaking
# ==============================================================================
backend/credentials.json
backend/token.json

# ==============================================================================
# ÆHub ACADEMIC MODULE SPECIFIC (CRITICAL)
# Prevents sensitive academic grades and session tokens from leaking to Git bounds
# ==============================================================================
backend/academic_cache.json
backend/chat_history.json
backend/phoenix_debug.png
backend/playwright_sessions/